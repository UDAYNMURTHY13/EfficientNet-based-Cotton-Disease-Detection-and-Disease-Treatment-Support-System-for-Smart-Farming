# CottonCare AI - Development Environment Configuration

# Application
DEBUG=True
APP_ENV=development

# Database - Using SQLite for development (simple file-based DB)
# Change to PostgreSQL URL for production
DATABASE_URL=sqlite:///./cottoncare_dev.db

# API Configuration
HOST=0.0.0.0
PORT=8000

# JWT Secrets
SECRET_KEY=dev-secret-key-please-change-in-production-use-strong-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Machine Learning
MODEL_PATH=cotton_model_final.keras
ENABLE_XAI=True

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif
UPLOAD_DIR=uploads

# Logging
LOG_LEVEL=INFO
SQLALCHEMY_ECHO=False

# CORS (for frontend on different port)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000"]

# Email (optional for notifications)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SENDMAIL_FROM=

# Geolocation API
GEOLOCATION_SERVICE=nominatim
