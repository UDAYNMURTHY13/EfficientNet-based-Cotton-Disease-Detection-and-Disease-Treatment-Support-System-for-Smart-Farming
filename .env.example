# CottonCare AI - Environment Configuration
# Copy this to .env and update with your settings

# Application
DEBUG=False
APP_NAME="CottonCare AI"
APP_VERSION="1.0.0"

# Server
HOST=0.0.0.0
PORT=8001

# Database - PostgreSQL (LOCAL DEVELOPMENT)
DATABASE_URL=postgresql://cottoncare_user:cottoncare_password@localhost:5432/cottoncare_db
SQLALCHEMY_ECHO=False

# Database - PostgreSQL (PRODUCTION)
# DATABASE_URL=postgresql://user:password@prod-db-host:5432/cottoncare_prod

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-use-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ML Model
MODEL_PATH=cotton_model_final.keras
ENABLE_XAI=True

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# CORS - Local Development
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:8080"]

# CORS - Production (Update with your domains)
# CORS_ORIGINS=["https://app.cottoncare.com", "https://dashboard.cottoncare.com"]

# Email Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# AWS S3 Configuration (Optional)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Error Tracking (Optional - Sentry)
SENTRY_DSN=
